# ── ORC (the OAuth Authorization Server + MCP gateway) ──────────────────────
# Base URL of the ORC deployment. It is BOTH the OAuth issuer (Hydra behind
# nginx) and the host of the /mcp tool endpoint your backend calls.
ORC_URL=https://help.opsway.com

# OAuth client id, obtained once via Dynamic Client Registration:
#   APP_URL=http://localhost:3001 npm run register-client
# (see scripts/register-client.mjs; registers a public PKCE client — no secret)
ORC_CLIENT_ID=

# The ORC environment (= one Odoo instance) this app is pinned to.
# Find yours:  orc envs   → the ID column (UUID).
ORC_ENV_ID=

# ── This app ─────────────────────────────────────────────────────────────────
# Public base URL of THIS deployment. The OAuth redirect_uri is derived from it
# (`${APP_URL}/api/auth/callback`) and must be among the redirect_uris the
# client was registered with. Local dev: http://localhost:3001. On Vercel: your
# stable production URL (https://<project>.vercel.app) — NOT the per-deploy
# VERCEL_URL, which changes every deploy and would never match the registration.
APP_URL=http://localhost:3001
